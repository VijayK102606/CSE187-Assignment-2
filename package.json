{
  "name": "cse187-assignment2",
  "version": "1.2.0",
  "description": "CSE187 Assignment 2",
  "author": "David Harrison <dcharris@ucsc.edu>",
  "license": "UNLICENSED",
  "repository": "none",
  "devDependencies": {
    "@eslint/js": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/supertest": "*",
    "@vitest/coverage-v8": "*",
    "bestzip": "*",
    "eslint": "*",
    "eslint-config-typescript": "*",
    "globals": "*",
    "jscpd": "*",
    "nodemon": "*",
    "supertest": "*",
    "ts-node": "*",
    "ts-postgres": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "unplugin-swc": "*",
    "vite-plugin-eslint": "*",
    "vite-ts-decorators": "*",
    "vitest": "*"
  },
  "dependencies": {
    "class-validator": "*",
    "dotenv": "*",
    "express": "*",
    "graphql-http": "*",
    "graphql": "*",
    "graphql-playground-middleware-express": "*",
    "jsonwebtoken": "*",
    "pg": "*",
    "reflect-metadata": "*",
    "type-graphql": "*"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node src/server.ts"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "node build/server.js",
    "prebuild": "npm run lint",
    "build": "tsc",
    "dev": "nodemon",
    "pretest": "(npm run lint) && (npm run cpd)",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "rtest": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "cpd": "jscpd src test --silent",
    "lint": "eslint test/**/*.[jt]s src/**/*.[jt]s --fix",
    "zip": "bestzip CSE187.Assignment2.Submission.zip test/*.ts test/**/* src/*.ts src/**/* sql/schema.sql"
  }
}
